{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api-server": {
      "name": "api-server",
      "source": "artifacts/api-server",
      "watch": true,
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "pnpm start",
        "restartPolicyType": "ON_FAILURE",
        "healthcheckPath": "/health"
      }
    }
  }
}
